<input type="number" id="n1">
<input type="number" id="n2">
<select id="op">
    <option value="+">+</option>
    <option value="-">-</option>
    <option value="*">*</option>
    <option value="/">/</option>
</select>
<button onclick="calc()">Calcular</button>
<div id="resCalc"></div>

<script>
function calc(){
    let a = Number(document.getElementById("n1").value)
    let b = Number(document.getElementById("n2").value)
    let op = document.getElementById("op").value
    let r = 0

    if(op=="+") r = a + b
    if(op=="-") r = a - b
    if(op=="*") r = a * b
    if(op=="/") r = a / b

    document.getElementById("resCalc").innerText = r
}
</script>
