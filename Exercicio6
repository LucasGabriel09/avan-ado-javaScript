<input type="text" id="missao">
<button onclick="add()">Adicionar</button>
<ul id="missoes"></ul>

<script>
function add(){
    let txt = document.getElementById("missao").value
    let ul = document.getElementById("missoes")

    let li = document.createElement("li")
    li.innerText = txt

    li.onclick=function(){
        li.style.textDecoration="line-through"
    }

    ul.appendChild(li)
}
</script>
